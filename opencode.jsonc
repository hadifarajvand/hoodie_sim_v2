{
  "$schema": "https://opencode.ai/config.json",
  "model": "auto",
  "permission": {
    "*": "deny",
    "external_directory": "deny",
    "question": "deny",
    "doom_loop": "deny",
    "webfetch": "allow",
    "websearch": "deny",
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*secret*": "deny",
      "**/*credential*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "edit": {
      "*": "deny",
      "src/**": "allow",
      "app/**": "allow",
      "server/**": "allow",
      "backend/**": "allow",
      "frontend/**": "allow",
      "components/**": "allow",
      "pages/**": "allow",
      "lib/**": "allow",
      "tests/**": "allow",
      "__tests__/**": "allow",
      "AGENTS.md": "allow",
      ".opencode/**": "allow",
      "docs/**": "allow",
      "graphify-out/**": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny"
    },
    "bash": {
      "*": "deny",
      "pwd": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "git ls-files*": "allow",
      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "npm run typecheck*": "allow",
      "npm run build*": "allow",
      "npm run check*": "allow",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "pnpm run lint*": "allow",
      "pnpm run typecheck*": "allow",
      "pnpm run build*": "allow",
      "yarn test*": "allow",
      "yarn lint*": "allow",
      "yarn build*": "allow",
      "bun test*": "allow",
      "bun run build*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "python3 -m pytest*": "allow",
      "graphify query*": "allow",
      "graphify path*": "allow",
      "graphify explain*": "allow",
      "graphify update*": "allow",
      "graphify .": "allow",
      "npx ruflo@latest daemon status*": "allow",
      "npx ruflo@latest daemon start*": "allow",
      "npx ruflo@latest hive-mind status*": "allow",
      "npx ruflo@latest swarm status*": "allow",
      "npx ruflo@latest agent list*": "allow",
      "npx ruflo@latest agent spawn*": "allow",
      "npx ruflo@latest hooks route*": "allow",
      "npx ruflo@latest hooks explain*": "allow",
      "npx ruflo@latest hooks pre-task*": "allow",
      "npx ruflo@latest hooks post-task*": "allow",
      "npx ruflo@latest memory search*": "allow",
      "npx ruflo@latest memory store*": "allow",
      "npx ruflo@latest hive-mind init*": "allow",
      "npx ruflo@latest swarm init*": "allow",
      "rm *": "deny",
      "rm -rf*": "deny",
      "sudo *": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "curl *|sh": "deny",
      "wget *|sh": "deny",
      "docker compose down*": "deny",
      "docker system prune*": "deny",
      "vercel deploy*": "deny",
      "netlify deploy*": "deny",
      "firebase deploy*": "deny",
      "wrangler deploy*": "deny",
      "aws *": "deny",
      "gcloud *": "deny",
      "az *": "deny",
      "kubectl *": "deny",
      "terraform apply*": "deny",
      "terraform destroy*": "deny"
    }
  }
}
